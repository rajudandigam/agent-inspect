{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@agent-inspect/core": ["packages/core/src/index.ts"],
      "@agent-inspect/core/*": ["packages/core/src/*"],
      "agent-inspect": ["packages/core/src/index.ts"],
      "@agent-inspect/langchain": ["packages/langchain/src/index.ts"],
      "@agent-inspect/langchain/*": ["packages/langchain/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "packages/**/*.ts",
    "tsup.core.config.ts",
    "tsup.cli.config.ts",
    "tsup.langchain.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
