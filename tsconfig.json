{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@agent-inspect/core": ["packages/core/src/index.ts"],
      "@agent-inspect/core/advanced": ["packages/core/src/entries/advanced.ts"],
      "@agent-inspect/core/checks": ["packages/core/src/entries/checks.ts"],
      "@agent-inspect/core/diff": ["packages/core/src/entries/diff.ts"],
      "@agent-inspect/core/exporters": ["packages/core/src/entries/exporters.ts"],
      "@agent-inspect/core/logs": ["packages/core/src/entries/logs.ts"],
      "@agent-inspect/core/persisted": ["packages/core/src/entries/persisted.ts"],
      "@agent-inspect/core/readers": ["packages/core/src/entries/readers.ts"],
      "@agent-inspect/core/reporters": ["packages/core/src/entries/reporters.ts"],
      "@agent-inspect/core/writers": ["packages/core/src/entries/writers.ts"],
      "@agent-inspect/core/workspace": ["packages/core/src/entries/workspace.ts"],
      "@agent-inspect/core/*": ["packages/core/src/*"],
      "agent-inspect": ["packages/core/src/index.ts"],
      "agent-inspect/advanced": ["packages/core/src/entries/advanced.ts"],
      "agent-inspect/checks": ["packages/core/src/entries/checks.ts"],
      "agent-inspect/diff": ["packages/core/src/entries/diff.ts"],
      "agent-inspect/exporters": ["packages/core/src/entries/exporters.ts"],
      "agent-inspect/logs": ["packages/core/src/entries/logs.ts"],
      "agent-inspect/persisted": ["packages/core/src/entries/persisted.ts"],
      "agent-inspect/readers": ["packages/core/src/entries/readers.ts"],
      "agent-inspect/reporters": ["packages/core/src/entries/reporters.ts"],
      "agent-inspect/writers": ["packages/core/src/entries/writers.ts"],
      "agent-inspect/workspace": ["packages/core/src/entries/workspace.ts"],
      "@agent-inspect/langchain": ["packages/langchain/src/index.ts"],
      "@agent-inspect/langchain/*": ["packages/langchain/src/*"],
      "@agent-inspect/ai-sdk": ["packages/ai-sdk/src/index.ts"],
      "@agent-inspect/ai-sdk/*": ["packages/ai-sdk/src/*"],
      "@agent-inspect/vitest": ["packages/vitest/src/index.ts"],
      "@agent-inspect/vitest/*": ["packages/vitest/src/*"],
      "@agent-inspect/jest": ["packages/jest/src/index.ts"],
      "@agent-inspect/jest/*": ["packages/jest/src/*"],
      "@agent-inspect/openai-agents": ["packages/openai-agents/src/index.ts"],
      "@agent-inspect/openai-agents/*": ["packages/openai-agents/src/*"],
      "@agent-inspect/harness": ["packages/harness/src/index.ts"],
      "@agent-inspect/harness/*": ["packages/harness/src/*"],
      "@agent-inspect/redact": ["packages/redact/src/index.ts"],
      "@agent-inspect/redact/*": ["packages/redact/src/*"],
      "@agent-inspect/eval": ["packages/eval/src/index.ts"],
      "@agent-inspect/eval/*": ["packages/eval/src/*"],
      "@agent-inspect/mcp": ["packages/mcp/src/index.ts"],
      "@agent-inspect/mcp/*": ["packages/mcp/src/*"],
      "@agent-inspect/guardrails": ["packages/guardrails/src/index.ts"],
      "@agent-inspect/guardrails/*": ["packages/guardrails/src/*"],
      "@agent-inspect/circuit": ["packages/circuit/src/index.ts"],
      "@agent-inspect/circuit/*": ["packages/circuit/src/*"],
      "@agent-inspect/viewer": ["packages/viewer/src/index.ts"],
      "@agent-inspect/viewer/*": ["packages/viewer/src/*"],
      "@agent-inspect/mcp-server": ["packages/mcp-server/src/index.ts"],
      "@agent-inspect/mcp-server/*": ["packages/mcp-server/src/*"],
      "@agent-inspect/adapter-sdk": ["packages/adapter-sdk/src/index.ts"],
      "@agent-inspect/adapter-sdk/*": ["packages/adapter-sdk/src/*"],
      "@agent-inspect/tui": ["packages/tui/src/index.ts"],
      "@agent-inspect/tui/*": ["packages/tui/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tsup.core.config.ts",
    "tsup.cli.config.ts",
    "tsup.langchain.config.ts",
    "tsup.ai-sdk.config.ts",
    "tsup.vitest.config.ts",
    "tsup.jest.config.ts",
    "tsup.openai-agents.config.ts",
    "tsup.harness.config.ts",
    "tsup.redact.config.ts",
    "tsup.eval.config.ts",
    "tsup.mcp.config.ts",
    "tsup.guardrails.config.ts",
    "tsup.circuit.config.ts",
    "tsup.viewer.config.ts",
    "tsup.mcp-server.config.ts",
    "tsup.adapter-sdk.config.ts",
    "tsup.tui.config.ts",
    "tsup.vscode.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
