{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@agent-inspect/core": ["packages/core/src/index.ts"],
      "@agent-inspect/core/checks": ["packages/core/src/entries/checks.ts"],
      "@agent-inspect/core/readers": ["packages/core/src/entries/readers.ts"],
      "@agent-inspect/core/*": ["packages/core/src/*"],
      "agent-inspect": ["packages/core/src/index.ts"],
      "agent-inspect/writers": ["packages/core/src/entries/writers.ts"],
      "@agent-inspect/langchain": ["packages/langchain/src/index.ts"],
      "@agent-inspect/langchain/*": ["packages/langchain/src/*"],
      "@agent-inspect/ai-sdk": ["packages/ai-sdk/src/index.ts"],
      "@agent-inspect/ai-sdk/*": ["packages/ai-sdk/src/*"],
      "@agent-inspect/vitest": ["packages/vitest/src/index.ts"],
      "@agent-inspect/vitest/*": ["packages/vitest/src/*"],
      "@agent-inspect/jest": ["packages/jest/src/index.ts"],
      "@agent-inspect/jest/*": ["packages/jest/src/*"],
      "@agent-inspect/openai-agents": ["packages/openai-agents/src/index.ts"],
      "@agent-inspect/openai-agents/*": ["packages/openai-agents/src/*"],
      "@agent-inspect/tui": ["packages/tui/src/index.ts"],
      "@agent-inspect/tui/*": ["packages/tui/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tsup.core.config.ts",
    "tsup.cli.config.ts",
    "tsup.langchain.config.ts",
    "tsup.ai-sdk.config.ts",
    "tsup.vitest.config.ts",
    "tsup.jest.config.ts",
    "tsup.openai-agents.config.ts",
    "tsup.tui.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
