{
  "name": "@agent-inspect/langchain",
  "version": "6.7.3",
  "license": "MIT",
  "type": "module",
  "private": false,
  "description": "LangChain.js callback adapter for AgentInspect (in-memory or persisted JSONL execution events)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajudandigam/agent-inspect.git",
    "directory": "packages/langchain"
  },
  "bugs": {
    "url": "https://github.com/rajudandigam/agent-inspect/issues"
  },
  "homepage": "https://github.com/rajudandigam/agent-inspect/tree/main/packages/langchain",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "pnpm --workspace-root exec tsup --config tsup.langchain.config.ts",
    "test": "vitest run -c ../../vitest.config.ts"
  },
  "peerDependencies": {
    "@langchain/core": "^1.0.0"
  },
  "dependencies": {
    "agent-inspect": "workspace:*"
  },
  "devDependencies": {
    "@langchain/core": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
