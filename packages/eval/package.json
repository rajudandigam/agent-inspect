{
  "name": "@agent-inspect/eval",
  "version": "4.2.0",
  "license": "MIT",
  "type": "module",
  "description": "Deterministic local eval utilities for AgentInspect traces",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajudandigam/agent-inspect.git",
    "directory": "packages/eval"
  },
  "bugs": {
    "url": "https://github.com/rajudandigam/agent-inspect/issues"
  },
  "homepage": "https://github.com/rajudandigam/agent-inspect/tree/main/packages/eval",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "pnpm --workspace-root exec tsup --config tsup.eval.config.ts",
    "test": "vitest run -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@agent-inspect/circuit": "workspace:*",
    "@agent-inspect/guardrails": "workspace:*",
    "agent-inspect": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
